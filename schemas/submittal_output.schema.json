{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://winwater.local/schemas/submittal_output.schema.json",
  "title": "SubmittalOutput",
  "type": "object",
  "required": ["schema_version", "project", "submittal_number", "revision", "submittal_title", "items"],
  "properties": {
    "schema_version": {"type": "string"},
    "project": {
      "type": "object",
      "required": ["code", "name", "number"],
      "properties": {
        "code": {"type": "string"},
        "name": {"type": "string"},
        "number": {"type": "string"}
      }
    },
    "submittal_number": {"type": "string"},
    "revision": {"type": "string"},
    "submittal_title": {"type": "string"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_number", "description", "manufacturer", "model_number", "spec_section", "documents"],
        "properties": {
          "item_number": {"type": "integer", "minimum": 1},
          "description": {"type": "string", "minLength": 1},
          "manufacturer": {"type": "string", "minLength": 1},
          "model_number": {"type": "string", "minLength": 1},
          "spec_section": {"type": "string", "pattern": "^\\d{2} \\d{2} \\d{2}$"},
          "documents": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "path"],
              "properties": {
                "type": {"type": "string", "enum": ["cut_sheet", "certification", "spec_page", "other"]},
                "path": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
