{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://winwater.local/schemas/drawing_takeoff.schema.json",
  "title": "DrawingTakeoff",
  "type": "object",
  "required": ["project", "items", "drawing_notes", "assumptions"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "object",
      "required": ["code", "name"],
      "additionalProperties": false,
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1}
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "description",
          "manufacturer",
          "model_number",
          "spec_section",
          "quantity",
          "quantity_unit",
          "notes",
          "submittal_group",
          "confidence",
          "needs_review",
          "source_evidence"
        ],
        "additionalProperties": false,
        "properties": {
          "description": {"type": "string"},
          "manufacturer": {"type": "string"},
          "model_number": {"type": "string"},
          "spec_section": {"type": "string"},
          "quantity": {"type": ["number", "null"]},
          "quantity_unit": {"type": "string"},
          "notes": {"type": "string"},
          "submittal_group": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "needs_review": {"type": "boolean"},
          "source_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "document_path",
                "page_number",
                "page_label",
                "sheet_id",
                "evidence_quote",
                "reason"
              ],
              "additionalProperties": false,
              "properties": {
                "document_path": {"type": "string"},
                "page_number": {"type": "integer", "minimum": 1},
                "page_label": {"type": "string"},
                "sheet_id": {"type": ["string", "null"]},
                "evidence_quote": {"type": "string"},
                "reason": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "drawing_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["document_path", "page_number", "page_label", "sheet_id", "note_id", "text"],
        "additionalProperties": false,
        "properties": {
          "document_path": {"type": "string"},
          "page_number": {"type": "integer", "minimum": 1},
          "page_label": {"type": "string"},
          "sheet_id": {"type": ["string", "null"]},
          "note_id": {"type": "string"},
          "text": {"type": "string"}
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
